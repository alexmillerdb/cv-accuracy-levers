# Copy to .env for local IDE development. Keep secrets out of this file.

# Databricks auth/profile selection. Prefer CLI/OAuth profile auth in
# ~/.databrickscfg over storing tokens in .env.
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Databricks Connect serverless CPU for IDE smoke tests.
# If set, Databricks Connect ignores DATABRICKS_CLUSTER_ID.
DATABRICKS_SERVERLESS_COMPUTE_ID=auto
# Optional classic compute fallback:
# DATABRICKS_CLUSTER_ID=0123-456789-abcd123

# MLflow tracking from IDE to Databricks.
MLFLOW_TRACKING_URI=databricks
MLFLOW_REGISTRY_URI=databricks-uc

# Prefer experiment ID for stable IDE logging. Use name only if ID is not known.
MLFLOW_EXPERIMENT_ID=
# MLFLOW_EXPERIMENT_NAME=/Shared/cv-accuracy-levers

# Unity Catalog defaults used by notebooks/scripts.
CV_CATALOG=serverless_stable_yau46e_catalog
CV_SCHEMA=cv_accuracy_levers
CV_VOLUME=cv_accuracy_levers
CV_VOLUME_SUBPATH=artifacts

# Public dataset ingest defaults. Keep manifests and images out of git.
CV_DATA_SOURCE=manifest
CV_DATA_MANIFEST=
CV_DATA_DIR=
# Optional UC ingest targets for normalized manifest and image staging.
CV_UC_TABLE=image_manifest
# Optional only for local RF100-VL export/download workflows. Never commit keys.
# ROBOFLOW_API_KEY=

# Runtime metadata logged with MLflow runs.
CV_RUNTIME=local_cpu
SAMPLE_MODE=true
